<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

    <PropertyGroup>
        <OutputType>Library</OutputType>
        <TargetFramework>net462</TargetFramework>
        <RootNamespace>QuickLook.Plugin.DbViewer</RootNamespace>
        <AssemblyName>QuickLook.Plugin.DbViewer</AssemblyName>
        <UseWPF>true</UseWPF>
        <LangVersion>latest</LangVersion>
        <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
        <CodeAnalysisRuleSet>MinimumRecommendedRules.ruleset</CodeAnalysisRuleSet>
        <ProjectGuid>{A3B2482D-3BEA-4BB8-9F3B-5D8C7FCB8761}</ProjectGuid>
        <PlatformTarget>AnyCPU</PlatformTarget>
        <Platforms>AnyCPU;x64;ARM64</Platforms>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|AnyCPU'">
        <DebugSymbols>true</DebugSymbols>
        <DebugType>full</DebugType>
        <Optimize>false</Optimize>
        <OutputPath>..\..\Build\Debug\QuickLook.Plugin\QuickLook.Plugin.DbViewer\</OutputPath>
        <DefineConstants>DEBUG;TRACE</DefineConstants>
        <ErrorReport>prompt</ErrorReport>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|ARM64'">
        <DebugSymbols>true</DebugSymbols>
        <DebugType>full</DebugType>
        <Optimize>false</Optimize>
        <OutputPath>..\..\Build\Debug\QuickLook.Plugin\QuickLook.Plugin.DbViewer\</OutputPath>
        <DefineConstants>DEBUG;TRACE</DefineConstants>
        <ErrorReport>prompt</ErrorReport>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|AnyCPU'">
        <DebugType>pdbonly</DebugType>
        <Optimize>true</Optimize>
        <OutputPath>..\..\Build\Release\QuickLook.Plugin\QuickLook.Plugin.DbViewer\</OutputPath>
        <DefineConstants>TRACE</DefineConstants>
        <ErrorReport>prompt</ErrorReport>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|ARM64'">
        <DebugType>pdbonly</DebugType>
        <Optimize>true</Optimize>
        <OutputPath>..\..\Build\Release\QuickLook.Plugin\QuickLook.Plugin.DbViewer\</OutputPath>
        <DefineConstants>TRACE</DefineConstants>
        <ErrorReport>prompt</ErrorReport>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x86'">
        <DebugSymbols>true</DebugSymbols>
        <DebugType>full</DebugType>
        <Optimize>false</Optimize>
        <OutputPath>..\..\Build\Debug\QuickLook.Plugin\QuickLook.Plugin.DbViewer\</OutputPath>
        <DefineConstants>DEBUG;TRACE</DefineConstants>
        <PlatformTarget>x86</PlatformTarget>
        <ErrorReport>prompt</ErrorReport>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x86'">
        <OutputPath>..\..\Build\Release\QuickLook.Plugin\QuickLook.Plugin.DbViewer\</OutputPath>
        <DefineConstants>TRACE</DefineConstants>
        <Optimize>true</Optimize>
        <DebugType>pdbonly</DebugType>
        <PlatformTarget>x86</PlatformTarget>
        <ErrorReport>prompt</ErrorReport>
    </PropertyGroup>

    <ItemGroup>
        <!--
            Microsoft.Data.Sqlite.Core — core library without a bundled native SQLite.
            SQLitePCLRaw.bundle_e_sqlcipher — replaces the default bundle with SQLCipher,
            which adds AES-256 encryption support. Plain databases are still compatible.
        -->
        <PackageReference Include="Microsoft.Data.Sqlite.Core" Version="10.0.9" />
        <PackageReference Include="SQLitePCLRaw.bundle_e_sqlcipher" Version="2.1.11" />
        <PackageReference Include="LiteDB" Version="5.0.21" />
        <PackageReference Include="MiniExcel" Version="1.44.1" />
    </ItemGroup>

    <!--
        .NET Framework does NOT auto-flatten runtimes/<rid>/native/*.dll to the output
        root. SQLitePCLRaw searches for e_sqlcipher.dll in the app directory, so copy it.
    -->
    <Target Name="CopySQLCipherNative" AfterTargets="Build">
        <Copy SourceFiles="$(OutputPath)runtimes\win-x64\native\e_sqlcipher.dll" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" Condition="Exists('$(OutputPath)runtimes\win-x64\native\e_sqlcipher.dll')" />
        <Copy SourceFiles="$(OutputPath)runtimes\win-arm64\native\e_sqlcipher.dll" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" Condition="Exists('$(OutputPath)runtimes\win-arm64\native\e_sqlcipher.dll')" />
    </Target>

    <Target Name="ReduceReleasePackaging" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
        <!-- Not supported on ARM32 -->
        <Delete Files="$(OutputPath)runtimes\win-arm\native\e_sqlcipher.dll" Condition="Exists('$(OutputPath)runtimes\win-arm\native\e_sqlcipher.dll')" />
        <RemoveDir Directories="$(OutputPath)runtimes\win-arm\native" Condition="Exists('$(OutputPath)runtimes\win-arm\native')" />
        <!-- Not supported for the duplicated -->
        <Delete Files="$(OutputPath)e_sqlcipher.dll" Condition="Exists('$(OutputPath)e_sqlcipher.dll')" />
    </Target>

    <ItemGroup>
        <ProjectReference Include="..\..\QuickLook.Common\QuickLook.Common.csproj">
            <Project>{85FDD6BA-871D-46C8-BD64-F6BB0CB5EA95}</Project>
            <Name>QuickLook.Common</Name>
            <Private>False</Private>
        </ProjectReference>
    </ItemGroup>

    <ItemGroup>
        <None Include="Translations.config">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <Compile Include="..\..\GitVersion.cs">
            <Link>Properties\GitVersion.cs</Link>
        </Compile>
    </ItemGroup>

</Project>
