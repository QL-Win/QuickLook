<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Wpf.Ui.Violeta.Controls">

    <Style x:Key="DefaultPaginationButtonStyle" TargetType="{x:Type local:PaginationButton}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Background" Value="#FFF0F0F0" />
        <Setter Property="Foreground" Value="#FF1F1F1F" />
        <Setter Property="BorderBrush" Value="#FFB0B0B0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PaginationButton}">
                    <Border x:Name="ContentBorder"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="PageNumber"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{Binding Page, RelativeSource={RelativeSource TemplatedParent}}" />
                            <TextBlock x:Name="Ellipsis"
                                       FontSize="16"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="..."
                                       Visibility="Collapsed" />
                            <TextBlock x:Name="LeftArrow"
                                       FontSize="16"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="‹"
                                       Visibility="Collapsed" />
                            <TextBlock x:Name="RightArrow"
                                       FontSize="16"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="›"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFastForward" Value="True">
                            <Setter TargetName="PageNumber" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="Ellipsis" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsFastBackward" Value="True">
                            <Setter TargetName="PageNumber" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="Ellipsis" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsFastForward" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Ellipsis" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="LeftArrow" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsFastBackward" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Ellipsis" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ContentBorder" Property="Background" Value="#FFD8D8D8" />
                            <Setter TargetName="PageNumber" Property="Foreground" Value="#FF000000" />
                            <Setter TargetName="Ellipsis" Property="Foreground" Value="#FF000000" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ContentBorder" Property="Background" Value="#FFB8B8B8" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentBorder" Property="Background" Value="#FFE8E8E8" />
                            <Setter TargetName="PageNumber" Property="Foreground" Value="#FF7A7A7A" />
                            <Setter TargetName="Ellipsis" Property="Foreground" Value="#FF7A7A7A" />
                            <Setter TargetName="LeftArrow" Property="Foreground" Value="#FF7A7A7A" />
                            <Setter TargetName="RightArrow" Property="Foreground" Value="#FF7A7A7A" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ContentBorder" Property="Background" Value="#FF3A8DFF" />
                            <Setter TargetName="ContentBorder" Property="BorderBrush" Value="#FF2A6FE8" />
                            <Setter TargetName="PageNumber" Property="Foreground" Value="#FFFFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DefaultPaginationStyle" TargetType="{x:Type local:Pagination}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Pagination}">
                    <StackPanel HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                Orientation="Horizontal">
                        <RepeatButton x:Name="PART_PreviousButton"
                                      Margin="0,0,4,0"
                                      VerticalAlignment="Center"
                                      Cursor="Hand"
                                      FocusVisualStyle="{x:Null}"
                                      Focusable="False">
                            <TextBlock FontSize="12" Text="‹" />
                        </RepeatButton>
                        <StackPanel x:Name="PART_ButtonPanel"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal" />
                        <RepeatButton x:Name="PART_NextButton"
                                      Margin="4,0,0,0"
                                      VerticalAlignment="Center"
                                      Cursor="Hand"
                                      FocusVisualStyle="{x:Null}"
                                      Focusable="False">
                            <TextBlock FontSize="12" Text="›" />
                        </RepeatButton>
                        <StackPanel x:Name="QuickJumpPanel"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <TextBlock Margin="0,0,4,0"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       Text="{TemplateBinding QuickJumpPrefixText}" />
                            <TextBox x:Name="PART_QuickJumpInput"
                                     MinWidth="40"
                                     MaxWidth="200"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     TextAlignment="Center" />
                            <TextBlock Margin="4,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       Text="{TemplateBinding QuickJumpSuffixText}" />
                        </StackPanel>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
