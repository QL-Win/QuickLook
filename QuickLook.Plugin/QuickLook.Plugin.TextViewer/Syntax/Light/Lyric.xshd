<?xml version="1.0" encoding="utf-8"?>
<SyntaxDefinition name="Lyric" extensions=".lrc">

    <Digits name="Digits" bold="false" italic="false" color="#006400"/>

    <RuleSets>
        <RuleSet ignorecase="false">
            <Span name="CurlyBrace" stopateol="false" color="#800080" bold="false" italic="false">
                <Begin>\{</Begin>
                <End>\}</End>
            </Span>
            <Span name="SquareBrace" stopateol="false" color="#C04000" bold="false" italic="false">
                <Begin>\[</Begin>
                <End>\]</End>
            </Span>
        </RuleSet>
    </RuleSets>
</SyntaxDefinition>