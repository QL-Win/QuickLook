<?xml version="1.0" encoding="utf-8"?>
<SyntaxDefinition name="Markdown" extensions=".md;.markdown;.mdx;.mmd;.mkd;.mdwn;.mdown;.mdc;.qmd;.rmd;.rmarkdown;.apib;.mdtxt;.mdtext">

    <RuleSets>
        <RuleSet name="CSharpRef" reference="C#"/>

        <RuleSet ignorecase="true">
            <Span name="CodeBlock" rule="CSharpRef" stopateol="false" color="#705711" bold="false" italic="false">
                <Begin>```</Begin>
                <End>```</End>
            </Span>
            <Span name="CodeIndentTab" rule="CSharpRef" stopateol="false" color="#705711" bold="false" italic="false">
                <Begin></Begin>
                <End>^(?!)</End>
            </Span>
            <Span name="Heading" stopateol="true" color="Maroon" bold="true" italic="false">
                <Begin>#</Begin>
            </Span>
            <Span name="Bold" stopateol="true" color="Black" bold="true" italic="false">
                <Begin>\*\*</Begin>
                <End>\*\*</End>
            </Span>
            <Span name="BoldUnderscore" stopateol="true" color="Black" bold="true" italic="false">
                <Begin>__</Begin>
                <End>__</End>
            </Span>
            <Span name="InlineCode" stopateol="true" color="#705711" bold="false" italic="false">
                <Begin>`</Begin>
                <End>`</End>
            </Span>
            <Span name="BlockQuote" stopateol="true" color="DarkBlue" bold="false" italic="false">
                <Begin>&gt;</Begin>
            </Span>
            <Span name="Link" stopateol="true" color="Blue" bold="false" italic="false">
                <Begin>\[</Begin>
                <End>)</End>
            </Span>
            <Span name="Image" stopateol="true" color="Green" bold="false" italic="false">
                <Begin>!\[</Begin>
                <End>]</End>
            </Span>
            <Span name="Think" stopateol="false" color="#999999" bold="false" italic="false">
                <Begin>&lt;think&gt;</Begin>
                <End>&lt;/think&gt;</End>
            </Span>
        </RuleSet>
    </RuleSets>
</SyntaxDefinition>